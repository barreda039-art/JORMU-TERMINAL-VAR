# Capital.com API Credentials
# Obtén estas desde: Mi Cuenta → API → Generar Key
CAPITAL_API_KEY=TU_API_KEY_AQUI
CAPITAL_API_PASSWORD=TU_CONTRASENA_AQUI
CAPITAL_IDENTIFIER=TU_EMAIL_AQUI

# Modo: demo | live
CAPITAL_ENV=demo

# URLs (no modificar)
CAPITAL_DEMO_URL=https://demo-api-capital.backend.cylinder.co.uk/api/v1
CAPITAL_LIVE_URL=https://api-capital.backend.cylinder.co.uk/api/v1

# ICARO V2.1 — Alpaca API (para datos macro)
# Obtén una cuenta gratuita en: https://alpaca.markets
ALPACA_API_KEY=TU_ALPACA_KEY_AQUI
ALPACA_API_SECRET=TU_ALPACA_SECRET_AQUI
ALPACA_BASE_URL=https://data.alpaca.markets
